# Resend API key — get it at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Sender address — use onboarding@resend.dev for testing (no domain needed)
# In production, set this to noreply@yourdomain.com (requires verified domain in Resend)
FROM_EMAIL=onboarding@resend.dev

# Email address where contact form submissions will be delivered
TO_EMAIL=elaine.teixeira.psy@gmail.com

# (Optional) Restrict CORS to production domain
ALLOWED_ORIGIN=https://yourdomain.com
